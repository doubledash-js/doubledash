{
  "name": "@foragefox/doubledash",
  "version": "2.0.2",
  "description": "DoubleDash is simple utility library meant to help transition people off of jQuery.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doubledash-js/doubledash.git"
  },
  "sideEffects": false,
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./browser": "./dist/doubledash.js",
    "./animate.css": "./dist/doubledash-animate.css",
    "./animate.min.css": "./dist/doubledash-animate.min.css"
  },
  "unpkg": "dist/doubledash.js",
  "jsdelivr": "dist/doubledash.js",
  "files": [
    "dist",
    "src",
    "docs",
    "README.md"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --silent=false",
    "css": "npm-run-all css-compile css-compress",
    "css-compile": "sass src/animation/css/animate.scss dist/doubledash-animate.css",
    "css-compress": "sass dist/doubledash-animate.css dist/doubledash-animate.min.css --style compressed",
    "js": "webpack"
  },
  "jest": {
    "verbose": true,
    "silent": false,
    "testEnvironment": "jest-environment-node",
    "transform": {},
    "setupFiles": [
      "./test/config/mocks/dom.js"
    ]
  },
  "author": "Demetri Mihalakakos",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.14.3",
    "@babel/preset-env": "^7.14.4",
    "babel-loader": "^8.2.2",
    "denoify": "^1.6.17",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.34.0",
    "webpack": "^5.26.1",
    "webpack-cli": "^4.6.0"
  }
}
